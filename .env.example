# fair-do — environment variables
# Copy to .env.local for local dev; set the same keys in the Vercel project for prod.
# Generated from `process.env.*` usage across src/, scripts/, monitoring/. Keep in sync.
# NEVER commit real secrets — this file holds placeholders only.

# ── Core infrastructure ──────────────────────────────────────────────────────
# Postgres on Neon. DATABASE_URL = pooled (-pooler host). DIRECT_URL = non-pooler
# host (Prisma migrate/db push need a direct connection; PgBouncer breaks advisory locks).
DATABASE_URL="postgresql://USER:PASS@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASS@HOST.REGION.aws.neon.tech/DB?sslmode=require"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Auth — Clerk ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# ── Payments — Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Subscription Price IDs (create in Stripe Dashboard; live + test differ)
STRIPE_PRICE_PRO="price_..."            # teacher Pro £29/mo
STRIPE_PRICE_SCHOOL="price_..."         # teacher School £79/mo
STRIPE_PRICE_PARENT_PORTAL="price_..."  # parent portal £4.99/mo (per family)

# ── Video — Daily.co ─────────────────────────────────────────────────────────
DAILY_API_KEY="..."
DAILY_WEBHOOK_SECRET="..."

# ── Email — Resend ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM="fair-do <hello@fair-do.com>"
ALERT_EMAIL="ops@fair-do.com"           # ops alerts (falls back to FOUNDER_EMAIL)
COMPLAINTS_EMAIL="complaints@fair-do.com"
FOUNDER_EMAIL="founder@fair-do.com"
FOUNDER_EMAILS="founder@fair-do.com"    # comma-separated; /founder access

# ── SMS — Twilio (session reminders) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_FROM="+44..."
TWILIO_MESSAGING_SERVICE_SID="MG..."

# ── AI — Anthropic (lesson notes, support inbox agent) ───────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Image hosting — Cloudinary ───────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="..."
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="..."

# ── Rate limiting — Upstash Redis ────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://....upstash.io"
UPSTASH_REDIS_REST_TOKEN="..."

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY="..."
VAPID_PRIVATE_KEY="..."
NEXT_PUBLIC_VAPID_PUBLIC_KEY="..."      # same value as VAPID_PUBLIC_KEY, client-side
VAPID_SUBJECT="mailto:ops@fair-do.com"

# ── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN="https://...@sentry.io/..."          # set this to enable error tracking
NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
METRICS_TOKEN="..."                              # guards GET /api/metrics
PLAUSIBLE_API_KEY="..."
PLAUSIBLE_SITE_ID="fair-do.com"
PLAUSIBLE_API_HOST="https://plausible.io"

# ── Support inbox (IMAP) ─────────────────────────────────────────────────────
IMAP_HOST="imap.example.com"
IMAP_PORT="993"
IMAP_USER="support@fair-do.com"
IMAP_PASSWORD="..."
IMAP_MAILBOX="INBOX"
GH_PAT="ghp_..."                        # inbox agent files GitHub issues

# ── CAPTCHA — Cloudflare Turnstile ───────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY="..."
TURNSTILE_SECRET_KEY="..."

# ── Credential checks — Onfido ───────────────────────────────────────────────
ONFIDO_API_TOKEN="..."

# ── Whiteboard — Excalidraw ──────────────────────────────────────────────────
EXCALIDRAW_ROOM_SECRET="..."
EXCALIDRAW_SERVER_URL="https://..."

# ── Cron auth ────────────────────────────────────────────────────────────────
CRON_SECRET="..."                       # Vercel Cron sends Authorization: Bearer $CRON_SECRET

# ── Ops alert thresholds (optional; sensible defaults in code) ────────────────
# ALERT_DB_LATENCY_MS=500
# ALERT_UNREAD_MAIL=20
# ALERT_OPEN_COMPLAINTS=1
# ALERT_REPEAT_HOURS=6

# ── Feature flags (all default OFF unless noted; "true" to enable) ────────────
BOOKINGS_ENABLED="false"                # global booking gate (server)
NEXT_PUBLIC_BOOKINGS_ENABLED="false"    # global booking gate (UI) — keep in sync
PRACTICE_PORTAL_ENABLED="false"         # teacher practice/student-management portal
PARENT_PORTAL_ENABLED="false"           # parent portal (P2-3)
RECURRING_ENABLED="false"               # standing bookings + charge cron (P2-2)
RESOURCES_ENABLED="false"               # file/homework sharing (P2-5)
WHITEBOARD_ENABLED="false"              # Excalidraw whiteboard (P2-1)
AI_NOTES_ENABLED="false"                # Claude lesson notes (P2-4)
NEXT_PUBLIC_DIRECTORY_ENABLED="false"   # public tutor directory/marketplace
I18N_ENABLED="false"                    # internationalisation
ADMIN_IMPERSONATION_ENABLED="false"     # admin "log in as user"
NEXT_PUBLIC_DEMO_MODE="false"           # UAT/demo banner
ALLOW_DEMO_DATA="false"                 # permit demo seed data
SELFBOOK_REQUIRE_CONFIRM="true"         # double opt-in for public self-bookings
# FOUNDING_OFFER defaults ON (founding-tutor fee); set to "false" to disable
FOUNDING_OFFER="true"

# ── US expansion ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ACTIVE_US_STATES=""         # comma-separated live US state codes, e.g. "CA,NY"
