{
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && npx prisma migrate deploy && next build",
  "env": {
    "NODE_VERSION": "20"
  },
  "crons": [
    { "path": "/api/cron/reminders", "schedule": "0 * * * *" },
    { "path": "/api/cron/no-shows", "schedule": "15 * * * *" },
    { "path": "/api/cron/credentials", "schedule": "0 8 * * *" },
    { "path": "/api/cron/alerts", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/fx", "schedule": "30 6 * * *" },
    { "path": "/api/cron/inbox", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/recurring", "schedule": "0 7 * * *" }
  ]
}
